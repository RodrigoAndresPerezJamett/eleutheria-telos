{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eleutheria-telos",
  "version": "0.1.0",
  "identifier": "com.eleutheria.telos",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
